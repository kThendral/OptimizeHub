# OptimizeHub Backend — Environment Variables
# Copy this file to .env and fill in real values (never commit .env)
#
# DEPLOYMENT MODEL: Single Render Web Service
#   The Celery worker runs as a background thread inside the same FastAPI
#   process (started in app/main.py lifespan). No separate worker service,
#   no render.yaml Blueprint needed — deploy as one Render Web Service via
#   the Render dashboard with startCommand:
#     uvicorn app.main:app --host 0.0.0.0 --port $PORT

# Supabase — get from https://app.supabase.com/project/<your-project>/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Upstash Redis — get from https://console.upstash.com
# Format: rediss://default:PASSWORD@HOST.upstash.io:6379  (note: rediss:// with TLS)
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_UPSTASH_HOST.upstash.io:6379

# Modal — get from https://modal.com/settings (token_id + token_secret)
MODAL_TOKEN_ID=your_modal_token_id_here
MODAL_TOKEN_SECRET=your_modal_token_secret_here

# Runtime environment
ENVIRONMENT=development
PYTHONUNBUFFERED=1
